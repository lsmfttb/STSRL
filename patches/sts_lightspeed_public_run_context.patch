+                    pybind11::dict row;
+                    row["option_index"] = cidx;
+                    row["id"] = static_cast<int>(card.getId());
+                    row["name"] = std::string(card.getName());
+                    row["type"] = cardTypeLabel(card.getType());
+                    row["rarity"] = cardRarityStrings[static_cast<int>(card.getRarity())];
+                    row["upgraded"] = card.isUpgraded();
+                    reward_cards.append(row);
+                }
+                cr["cards"] = reward_cards;
+                cr["singing_bowl_available"] = gc.hasRelic(RelicId::SINGING_BOWL);
+                cardRewards.append(cr);
+            }
+            rewards["card_rewards"] = cardRewards;
+            pybind11::list relics;
+            for (int idx = 0; idx < rc.relicCount; ++idx) {
+                pybind11::dict row;
+                row["option_index"] = idx;
+                row["id"] = static_cast<int>(rc.relics[idx]);
+                row["name"] = std::string(getRelicName(rc.relics[idx]));
+                relics.append(row);
+            }
+            rewards["relics"] = relics;
+            pybind11::list potions;
+            for (int idx = 0; idx < rc.potionCount; ++idx) {
+                pybind11::dict row;
+                row["option_index"] = idx;
+                row["id"] = static_cast<int>(rc.potions[idx]);
+                row["name"] = potionLabel(rc.potions[idx]);
+                potions.append(row);
+            }
+            rewards["potions"] = potions;
+            rewards["emerald_key"] = rc.emeraldKey;
+            rewards["sapphire_key"] = rc.sapphireKey;
+            ret["rewards"] = rewards;
+            break;
+        }
+        case ScreenState::BOSS_RELIC_REWARDS: {
+            pybind11::dict br;
+            pybind11::list brelics;
+            for (int idx = 0; idx < 3; ++idx) {
+                pybind11::dict row;
+                row["option_index"] = idx;
+                row["id"] = static_cast<int>(gc.info.bossRelics[idx]);
+                row["name"] = std::string(getRelicName(gc.info.bossRelics[idx]));
+                brelics.append(row);
+            }
+            br["relics"] = brelics;
+            ret["boss_relic_rewards"] = br;
+            break;
+        }
+        case ScreenState::CARD_SELECT: {
+            pybind11::dict cs;
+            cs["select_type"] = "CARD_SELECT";
+            cs["required_count"] = gc.info.toSelectCount;
+            cs["selected_count"] = gc.info.haveSelectedCards.size();
+            pybind11::list selectOpts;
+            for (int idx = 0; idx < gc.info.toSelectCards.size(); ++idx) {
+                const auto &card = gc.info.toSelectCards[idx].card;
+                pybind11::dict row;
+                row["option_index"] = idx;
+                row["id"] = static_cast<int>(card.getId());
+                row["name"] = std::string(card.getName());
+                row["type"] = cardTypeLabel(card.getType());
+                row["rarity"] = cardRarityStrings[static_cast<int>(card.getRarity())];
+                row["upgraded"] = card.isUpgraded();
+                selectOpts.append(row);
+            }
+            cs["options"] = selectOpts;
+            ret["card_select"] = cs;
+            break;
+        }
+        case ScreenState::MAP_SCREEN:
+            ret["visible_map"] = visibleMapSnapshot(gc);
+            ret["current_map_node"] = currentMapNodeSnapshot(gc);
+            ret["next_map_nodes"] = nextMapNodesSnapshot(gc);
+            break;
+        case ScreenState::TREASURE_ROOM: {
+            pybind11::dict tr;
+            tr["chest_size"] = chestSizeEnumNames[static_cast<int>(gc.info.chestSize)];
+            ret["treasure"] = tr;
+            break;
+        }
+        case ScreenState::REST_ROOM: {
+            pybind11::dict rr;
+            pybind11::list restOpts;
+            for (int idx = 0; idx < 7; ++idx) {
+                pybind11::dict row;
+                row["option_index"] = idx;
+                if (idx == 0) row["label"] = "REST";
+                else if (idx == 1) row["label"] = "SMITH";
+                else if (idx == 2) row["label"] = "RECALL";
+                else if (idx == 3) row["label"] = "LIFT";
+                else if (idx == 4) row["label"] = "TOKE";
+                else if (idx == 5) row["label"] = "DIG";
+                else row["label"] = "UNKNOWN";
+                restOpts.append(row);
+            }
+            rr["options"] = restOpts;
+            ret["rest"] = rr;
+            break;
+        }
+        case ScreenState::SHOP_ROOM: {
+            const auto &shop = gc.info.shop;
+            pybind11::dict sh;
+            pybind11::list shopCards;
+            for (int idx = 0; idx < 7; ++idx) {
+                const auto price = shop.cardPrice(idx);
+                pybind11::dict row;
+                row["option_index"] = idx;
+                row["price"] = price;
+                row["sold_out"] = price < 0;
+                if (price >= 0) {
+                    const auto &card = shop.cards[idx];
+                    pybind11::dict item;
+                    item["id"] = static_cast<int>(card.getId());
+                    item["name"] = std::string(card.getName());
+                    item["type"] = cardTypeLabel(card.getType());
+                    item["rarity"] = cardRarityStrings[static_cast<int>(card.getRarity())];
+                    item["upgraded"] = card.isUpgraded();
+                    row["item"] = item;
+                }
+                shopCards.append(row);
+            }
+            sh["cards"] = shopCards;
+            sh["card_remove_price"] = shop.removeCost;
+            sh["card_remove_sold_out"] = shop.removeCost < 0;
+            ret["shop"] = sh;
+            break;
+        }
+        case ScreenState::BATTLE:
+            ret["projection_available"] = false;
+            missingFields.append("battle_screen_uses_battle_snapshot");
+            break;
+        case ScreenState::INVALID:
+        default:
+            ret["projection_available"] = false;
+            missingFields.append("unsupported_screen_state");
+            break;
+    }
+    ret["missing_fields"] = missingFields;
+    return ret;
+}
