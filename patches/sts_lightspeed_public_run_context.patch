+// ---------------------------------------------------------------------------
+// Public encounter history
+// ---------------------------------------------------------------------------
+
+struct PublicEncounterRecord {
+    int act = 0;
+    int floorNum = 0;
+    Room room = Room::INVALID;
+    MonsterEncounter encounter = MonsterEncounter::INVALID;
+};
+
+std::string visibleActBossLabel(const GameContext &gc) {
+    if (gc.act < 1 || gc.act > 4 || gc.boss == MonsterEncounter::INVALID) {
+        return "";
+    }
+    return monsterEncounterEnumNames[static_cast<int>(gc.boss)];
+}
+
+// ---------------------------------------------------------------------------
+// Map node projection
+// ---------------------------------------------------------------------------
+
+pybind11::dict publicMapNodeSnapshot(const MapNode &node, bool burningElite) {
+    pybind11::dict ret;
+    ret["symbol"] = std::string(1, node.getRoomSymbol());
+    ret["room_type"] = roomStrings[static_cast<int>(node.room)];
+    ret["burning_elite"] = burningElite;
+    ret["x"] = node.x;
+    ret["y"] = node.y;
+
+    pybind11::list parents;
+    for (int idx = 0; idx < node.parentCount; ++idx) {
+        pybind11::dict parent;
+        parent["x"] = node.parents[idx];
+        parent["y"] = node.y - 1;
+        parents.append(parent);
+    }
+    ret["parents"] = parents;
+
+    pybind11::list children;
+    for (int idx = 0; idx < node.edgeCount; ++idx) {
+        pybind11::dict child;
+        child["x"] = node.edges[idx];
+        child["y"] = node.y + 1;
+        children.append(child);
+    }
+    ret["children"] = children;
+    return ret;
+}
+
+pybind11::list visibleMapSnapshot(const GameContext &gc) {
+    pybind11::list ret;
+    if (gc.map == nullptr) {
+        return ret;
+    }
+    for (int y = 0; y < 15; ++y) {
+        for (int x = 0; x < 7; ++x) {
+            const auto &node = gc.map->getNode(x, y);
+            if (node.parentCount > 0 || node.edgeCount > 0) {
+                ret.append(publicMapNodeSnapshot(
+                        node,
+                        x == gc.map->burningEliteX && y == gc.map->burningEliteY));
+            }
+        }
+    }
+    return ret;
+}
+
+pybind11::dict currentMapNodeSnapshot(const GameContext &gc) {
+    if (gc.map == nullptr
+            || gc.curMapNodeX < 0 || gc.curMapNodeX >= 7
+            || gc.curMapNodeY < 0 || gc.curMapNodeY >= 15) {
+        return pybind11::dict();
+    }
+    return publicMapNodeSnapshot(
+            gc.map->getNode(gc.curMapNodeX, gc.curMapNodeY),
+            gc.curMapNodeX == gc.map->burningEliteX
+                    && gc.curMapNodeY == gc.map->burningEliteY);
+}
+
+pybind11::list nextMapNodesSnapshot(const GameContext &gc) {
+    pybind11::list ret;
+    if (gc.map == nullptr || gc.curMapNodeY >= 14) {
+        return ret;
+    }
+    if (gc.curMapNodeY < 0) {
+        for (int x = 0; x < 7; ++x) {
+            const auto &node = gc.map->getNode(x, 0);
+            if (node.edgeCount > 0) {
+                ret.append(publicMapNodeSnapshot(
+                        node,
+                        x == gc.map->burningEliteX && gc.map->burningEliteY == 0));
+            }
+        }
+        return ret;
+    }
+    const auto &current = gc.map->getNode(gc.curMapNodeX, gc.curMapNodeY);
+    for (int idx = 0; idx < current.edgeCount; ++idx) {
+        const auto nextY = gc.curMapNodeY + 1;
+        const auto nextX = current.edges[idx];
+        ret.append(publicMapNodeSnapshot(
+                gc.map->getNode(nextX, nextY),
+                nextX == gc.map->burningEliteX && nextY == gc.map->burningEliteY));
+    }
+    return ret;
+}
+
+pybind11::list publicEncounterHistorySnapshot(
+        const std::vector<PublicEncounterRecord> &history) {
+    pybind11::list ret;
+    for (const auto &record : history) {
+        pybind11::dict row;
+        row["act"] = record.act;
+        row["floor"] = record.floorNum;
+        row["room_type"] = roomStrings[static_cast<int>(record.room)];
+        row["encounter_id"] =
+                monsterEncounterEnumNames[static_cast<int>(record.encounter)];
+        ret.append(row);
+    }
+    return ret;
+}
