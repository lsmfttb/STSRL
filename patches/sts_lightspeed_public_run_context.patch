+                pybind11::dict row;
+                row["option_index"] = idx;
+                row["amount"] = rc.gold[idx];
+                gold.append(row);
+            }
+            rewards["gold"] = gold;
+            pybind11::list cardRewards;
+            for (int ridx = 0; ridx < rc.cardRewardCount; ++ridx) {
+                pybind11::dict cr;
+                cr["reward_index"] = ridx;
+                pybind11::list reward_cards;
